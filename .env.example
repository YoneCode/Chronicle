# ---------------------------------------------------------------------------
# Chronicle Omega — environment template.
# Copy to ".env" and fill in real values. NEVER commit ".env".
# ---------------------------------------------------------------------------

# Wallet private key used to deploy and to sign contract writes / run integration
# tests. Fund this account first via the Bradbury faucet:
#   https://testnet-faucet.genlayer.foundation/
# Format: 0x-prefixed 64-hex-char key. KEEP SECRET.
ACCOUNT_PRIVATE_KEY=0xyour_private_key_here

# Optional second account for multi-validator integration tests.
ACCOUNT_PRIVATE_KEY_2=

# Constructor arguments for ChronicleOmega(context_url, tolerance_bps).
# context_url: external context feed the validators read each epoch (untrusted).
# tolerance_bps: max leader/validator allocation divergence, 0..10000 (1500 = 15%).
CONTEXT_URL=https://api.example.com/context
TOLERANCE_BPS=1500

# Filled in AFTER deployment (printed by deploy script / CLI).
CONTRACT_ADDRESS=

# Local keystore password used by the genlayer CLI to encrypt the imported key
# on this VPS (headless, no OS keychain). Choose any non-empty string.
KEYSTORE_PASSWORD=change_me_local_only
